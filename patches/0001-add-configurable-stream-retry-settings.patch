index 04d973c86..1fdce7d0b 100644
--- a/codex-rs/core/src/util.rs
+++ b/codex-rs/core/src/util.rs
@@ -202,8 +202,12 @@ pub(crate) fn emit_feedback_auth_recovery_tags(
 }
 
 pub fn backoff(attempt: u64) -> Duration {
+    backoff_with_base(Duration::from_millis(INITIAL_DELAY_MS), attempt)
+}
+
+pub fn backoff_with_base(base_delay: Duration, attempt: u64) -> Duration {
     let exp = BACKOFF_FACTOR.powi(attempt.saturating_sub(1) as i32);
-    let base = (INITIAL_DELAY_MS as f64 * exp) as u64;
+    let base = (base_delay.as_millis() as f64 * exp) as u64;
     let jitter = rand::rng().random_range(0.9..1.1);
     Duration::from_millis((base as f64 * jitter) as u64)
 }
