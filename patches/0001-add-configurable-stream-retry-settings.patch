@@ -121,3 +128,70 @@ supports_websockets = true
     let provider: ModelProviderInfo = toml::from_str(provider_toml).unwrap();
     assert_eq!(provider.websocket_connect_timeout_ms, Some(15_000));
 }
+
+#[test]
+fn test_deserialize_stream_retry_backoff_config() {
+    let provider_toml = r#"
+name = "OpenAI"
+base_url = "https://api.openai.com/v1"
+stream_retry_delay_ms = 500
+stream_retry_backoff = "fixed"
+        "#;
+
+    let provider: ModelProviderInfo = toml::from_str(provider_toml).unwrap();
+    assert_eq!(provider.stream_retry_delay_ms, Some(500));
+    assert_eq!(provider.stream_retry_backoff, StreamRetryBackoff::Fixed);
+}
+
+#[test]
+fn test_stream_retry_delay_fixed_returns_exact_base_delay() {
+    let provider = ModelProviderInfo {
+        name: "Fixed".into(),
+        base_url: None,
+        env_key: None,
+        env_key_instructions: None,
+        experimental_bearer_token: None,
+        wire_api: WireApi::Responses,
+        query_params: None,
+        http_headers: None,
+        env_http_headers: None,
+        request_max_retries: None,
+        stream_max_retries: None,
+        stream_retry_delay_ms: Some(500),
+        stream_retry_backoff: StreamRetryBackoff::Fixed,
+        stream_idle_timeout_ms: None,
+        websocket_connect_timeout_ms: None,
+        requires_openai_auth: false,
+        supports_websockets: false,
+    };
+
+    assert_eq!(provider.stream_retry_delay(1), Duration::from_millis(500));
+    assert_eq!(provider.stream_retry_delay(10), Duration::from_millis(500));
+}
+
+#[test]
+fn test_stream_retry_delay_exponential_uses_configured_base_delay() {
+    let provider = ModelProviderInfo {
+        name: "Exponential".into(),
+        base_url: None,
+        env_key: None,
+        env_key_instructions: None,
+        experimental_bearer_token: None,
+        wire_api: WireApi::Responses,
+        query_params: None,
+        http_headers: None,
+        env_http_headers: None,
+        request_max_retries: None,
+        stream_max_retries: None,
+        stream_retry_delay_ms: Some(500),
+        stream_retry_backoff: StreamRetryBackoff::Exponential,
+        stream_idle_timeout_ms: None,
+        websocket_connect_timeout_ms: None,
+        requires_openai_auth: false,
+        supports_websockets: false,
+    };
+
+    let delay = provider.stream_retry_delay(3);
+    assert!(delay >= Duration::from_millis(1_800));
+    assert!(delay <= Duration::from_millis(2_200));
+}
