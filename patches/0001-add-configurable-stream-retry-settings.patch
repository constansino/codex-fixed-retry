 use std::time::Duration;
 
 const DEFAULT_STREAM_IDLE_TIMEOUT_MS: u64 = 300_000;
+const DEFAULT_STREAM_RETRY_DELAY_MS: u64 = 200;
 const DEFAULT_STREAM_MAX_RETRIES: u64 = 5;
 const DEFAULT_REQUEST_MAX_RETRIES: u64 = 4;
 pub(crate) const DEFAULT_WEBSOCKET_CONNECT_TIMEOUT_MS: u64 = 15_000;
@@ -66,6 +67,14 @@ impl<'de> Deserialize<'de> for WireApi {
     }
 }
 
+#[derive(Debug, Clone, Copy, Default, PartialEq, Eq, Deserialize, Serialize, JsonSchema)]
+#[serde(rename_all = "lowercase")]
+pub enum StreamRetryBackoff {
+    #[default]
+    Exponential,
+    Fixed,
+}
+
 /// Serializable representation of a provider definition.
 #[derive(Debug, Clone, Deserialize, Serialize, PartialEq, JsonSchema)]
 #[schemars(deny_unknown_fields)]
@@ -109,6 +118,13 @@ pub struct ModelProviderInfo {
     /// Number of times to retry reconnecting a dropped streaming response before failing.
     pub stream_max_retries: Option<u64>,
 
+    /// Base delay (in milliseconds) between stream reconnection attempts.
+    pub stream_retry_delay_ms: Option<u64>,
+
+    /// How the delay between stream reconnection attempts should evolve over time.
+    #[serde(default)]
+    pub stream_retry_backoff: StreamRetryBackoff,
+
     /// Idle timeout (in milliseconds) to wait for activity on a streaming response before treating
     /// the connection as lost.
     pub stream_idle_timeout_ms: Option<u64>,
@@ -225,6 +241,18 @@ impl ModelProviderInfo {
             .min(MAX_STREAM_MAX_RETRIES)
     }
 
+    /// Effective delay to wait before the next stream reconnection attempt.
+    pub fn stream_retry_delay(&self, attempt: u64) -> Duration {
+        let base_delay = self
+            .stream_retry_delay_ms
+            .map(Duration::from_millis)
+            .unwrap_or(Duration::from_millis(DEFAULT_STREAM_RETRY_DELAY_MS));
+        match self.stream_retry_backoff {
+            StreamRetryBackoff::Exponential => crate::util::backoff_with_base(base_delay, attempt),
+            StreamRetryBackoff::Fixed => base_delay,
+        }
+    }
+
     /// Effective idle timeout for streaming responses.
     pub fn stream_idle_timeout(&self) -> Duration {
         self.stream_idle_timeout_ms
@@ -267,6 +295,8 @@ impl ModelProviderInfo {
             // Use global defaults for retry/timeout unless overridden in config.toml.
             request_max_retries: None,
             stream_max_retries: None,
+            stream_retry_delay_ms: None,
+            stream_retry_backoff: StreamRetryBackoff::Exponential,
             stream_idle_timeout_ms: None,
             websocket_connect_timeout_ms: None,
             requires_openai_auth: true,
@@ -344,6 +374,8 @@ pub fn create_oss_provider_with_base_url(base_url: &str, wire_api: WireApi) -> M
         env_http_headers: None,
         request_max_retries: None,
